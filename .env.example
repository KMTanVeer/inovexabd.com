# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MONGODB_URI: Connection string for MongoDB Atlas
# Users configure this via the Secrets panel in the AI Studio UI.
MONGODB_URI=""

# JWT_SECRET: Secret for signing JWTs
JWT_SECRET="your_jwt_secret_here"

# ADMIN_EMAIL: Custom administrative login email (defaults to admin@inovexa.com)
ADMIN_EMAIL="admin@inovexa.com"

# ADMIN_PASSWORD: Plaintext password fallback (for local development use only)
ADMIN_PASSWORD="admin123"

# ADMIN_PASSWORD_HASH: Bcrypt hash of the administrator password (highly recommended for production)
# Example hash for "admin123": $2a$10$X86Z99N1hYxX2K1Jg1Y1JeyoD6m59eD9O3qV7zN.L/h0N1S2C7p3O
ADMIN_PASSWORD_HASH=""

# Cloudinary configuration for image uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
